APP_NAME=Chamse
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

# Token pour /setup (storage + migrations sans SSH) — à définir en production
DEPLOY_TOKEN=

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=chamse
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# CinetPay (Mobile Money / Carte)
# Récupérez vos identifiants sur https://app.cinetpay.com
# =============================================================================
CINETPAY_SITE_ID=
CINETPAY_API_KEY=
CINETPAY_SECRET_KEY=
CINETPAY_SANDBOX=true
CINETPAY_CURRENCY=XOF

# URLs personnalisées (optionnel, par défaut /checkout/confirmation, /webhook/cinetpay)
# CINETPAY_RETURN_URL=/checkout/confirmation
# CINETPAY_CANCEL_URL=/checkout/annulation
# CINETPAY_NOTIFY_URL=/webhook/cinetpay

# =============================================================================
# Lygos Pay
# Récupérez votre clé API sur https://dashboard.lygosapp.com
# =============================================================================
LYGOS_API_KEY=
LYGOS_API_BASE_URL=https://api.lygosapp.com/v1
LYGOS_CURRENCY=XOF

# URLs personnalisées (optionnel)
# LYGOS_RETURN_URL=/checkout/confirmation
# LYGOS_CANCEL_URL=/checkout/annulation
# LYGOS_NOTIFY_URL=/webhook/lygos

# =============================================================================
# AWS / Stockage (optionnel)
# =============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
